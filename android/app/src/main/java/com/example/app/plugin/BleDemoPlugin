@CapacitorPlugin(name = "BleDemoPlugin")
public class BleDemoPlugin extends Plugin {

  BU01_Service service;
  private Handler handler = new Handler();
  private static final int PERMISSION_COARSE_LOCATION = 1;
  List<BU01_Reader> readers = new ArrayList<>();
  List<EpcRecord> epcRecords = new ArrayList<>();
  BU01_Reader currentReader;
  private Handler mHandler = new Handler();
  private boolean inventorying = false;
  private boolean isStopped = false;


  public Runnable inventoryRunnable = new Runnable() {
    @Override
    public void run() {

    }
  };

   @RequiresApi(api = Build.VERSION_CODES.N)
  @PluginMethod()
  public void startScanningForReader(PluginCall call) {
    // Get ID/name of RFID reader to call
    String readerID = call.getString("value");
    Gson gson = new Gson();

    Collection<BU01_Reader> readerCollections = readers;

    if(null == readerID) {
      return;

    }
    BU01_Reader reader = readerCollections.stream().filter(carnet -> readerID.equals(carnet.getName())).findFirst().orElse(null);

    isStopped = false;

    inventoryRunnable = new Runnable() {
      @Override
      public void run() {
        reader.singleInventory((status, list) -> {
          if (status == 0){
            for (EpcReply epcReply : list){
              addEpcRecord(ByteUtils.epcBytes2Hex(epcReply.getEpc()), epcReply.getRssi());
            }
            final int total = epcRecords.size();

            JSObject ret = new JSObject();
            // If there are items found, return item names
            // else return null message

            EpcRecordsResults records = new EpcRecordsResults();
            records.setEpcRecords(epcRecords);

            ret.put("result",   gson.toJson(records).replace("\\", "\\\\"));
            notifyListeners("startScanningForReaderEvent", ret);
            inventorying = true;

          } else {
            mHandler.removeCallbacks(this);
            inventorying = false;

            if (!reader.isConnected()){
              //connect reader
              mHandler.removeCallbacks(this);
              reader.connect(getActivity(), new BU01_Reader.Callback() {
                @Override
                public void onConnect() {
                  currentReader = reader;
                  mHandler.postDelayed(inventoryRunnable, 100);
                }

                @Override
                public void onDisconnect() {
                  mHandler.removeCallbacks(inventoryRunnable);
                  currentReader = null;
                }
              });

                reader.isConnected();
            }
//            if (status == -205){
//              //inventory tag or other tag operation maybe return -205
//              CustomDialog.showLowPower(BleMainActivity.this);
//            } else {
//              showToast(String.format(getResources().getString(R.string.toast_err_start_inventory), status));
//            }
          }

          if (inventorying){
            mHandler.removeCallbacks(this);
            if(!isStopped){
              mHandler.postDelayed(this, 100);
            }

          }
        });
      }
    };
    mHandler.removeCallbacks(inventoryRunnable);
    mHandler.postDelayed(inventoryRunnable, 100);

  }

    @RequiresApi(api = Build.VERSION_CODES.N)
    @PluginMethod()
    public void scanOnce(PluginCall call){
        String readerID = call.getString("value");
        Gson gson = new Gson();

        Collection<BU01_Reader> readerCollections = readers;

        if(null == currentReader) {
        currentReader =  readerCollections.stream().filter(carnet -> readerID.equals(carnet.getName())).findFirst().orElse(null);

        }



        if (!currentReader.isConnected()){

        //connect reader
        currentReader.connect(getActivity(), new BU01_Reader.Callback() {
            @Override
            public void onConnect() {
            currentReader = currentReader;
            readDataFromScanner(call);
            }

            @Override
            public void onDisconnect() {

            }
        });
        }else {
        readDataFromScanner(call);
        }
    }

    public void addEpcRecord(String epc, float rssi){
        EpcRecord epcRecord = null;
        for (EpcRecord record : epcRecords){
        if (record.getEpc().equals(epc)){
            epcRecord = record;
            record.setCount(record.getCount() + 1);
            record.setRssi(rssi);
            break;
        }
        }
        if (epcRecord == null){
        epcRecords.add(new EpcRecord(epcRecords.size() + 1, epc, rssi));
        }
    //    notifyDataSetChanged();
    }
}
